# Blockchain Configuration for InsuChain

# ==================== REQUIRED ====================

# Your private key from MetaMask (WITHOUT 0x prefix)
# ⚠️  NEVER commit this file with actual values
# ⚠️  NEVER share your private key
PRIVATE_KEY=your_private_key_here

# RPC URL for Polygon Amoy testnet
# Get from: https://alchemy.com (free tier available)
# Or use: https://rpc-amoy.polygon.technology (public)
RPC_URL=https://rpc-amoy.polygon.technology

# ==================== OPTIONAL ====================

# Gas price gwei (optional, auto if not set)
GAS_PRICE=50

# Gas limit (optional, auto if not set)
GAS_LIMIT=5000000
