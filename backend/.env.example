# ==================== BACKEND CONFIGURATION ====================

# ==================== SERVER ====================
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# ==================== DATABASE ====================
# Option 1: Use DATABASE_URL connection string (for Neon PostgreSQL)
DATABASE_URL=postgresql://user:password@host:5432/database

# Option 2: Use individual database parameters (alternative to DATABASE_URL)
# DB_USER=neondb_owner
# DB_PASSWORD=your_password_here
# DB_HOST=ep-royal-thunder-amri5u5a-pooler.c-5.us-east-1.aws.neon.tech
# DB_PORT=5432
# DB_NAME=neondb

# ==================== JWT AUTHENTICATION ====================
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# ==================== ADMIN CREDENTIALS ====================
ADMIN_EMAIL=admin@insuchain.com
ADMIN_PASSWORD=AdminPassword123

# ==================== BLOCKCHAIN (Polygon Amoy Testnet) ====================
# Private key of the authorized account for blockchain transactions (WITHOUT 0x prefix)
PRIVATE_KEY=your_private_key_here

# RPC endpoint for Polygon Amoy testnet
RPC_URL=https://rpc-amoy.polygon.technology/

# Deployed Insurance smart contract address on Polygon Amoy
CONTRACT_ADDRESS=0xYourContractAddressHere

# ==================== WEATHER API ====================
# OpenWeatherMap API key for weather data (used for payout triggers)
WEATHER_API_KEY=your_openweathermap_api_key

# ==================== OPTIONAL FEATURES ====================
# Enable blockchain payout monitoring (default: enabled)
ENABLE_BLOCKCHAIN_MONITORING=true

# Enable weather-based automatic payouts (default: disabled)
ENABLE_WEATHER_MONITORING=false

# Default location for weather monitoring (latitude)
DEFAULT_LATITUDE=28.7041

# Default location for weather monitoring (longitude)
DEFAULT_LONGITUDE=77.1025
