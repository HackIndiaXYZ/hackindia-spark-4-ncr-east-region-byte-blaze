# ==================== DATABASE ====================
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"
PORT=5000

# ==================== JWT ====================
JWT_SECRET="your-secret-key-here"

# ==================== ADMIN ====================
ADMIN_EMAIL="admin@insuchain.com"
ADMIN_PASSWORD="AdminPassword123"

# ==================== BLOCKCHAIN (Polygon Amoy Testnet) ====================
# Private key (WITHOUT 0x prefix)
PRIVATE_KEY="your_private_key_here"

# RPC endpoint
RPC_URL="https://rpc-amoy.polygon.technology/"

# Deployed Insurance smart contract address
CONTRACT_ADDRESS="0xYourContractAddressHere"

# ==================== WEATHER API (OpenWeatherMap) ====================
# Get your free API key at: https://openweathermap.org/appid
WEATHER_API_KEY="your_openweathermap_api_key"

# ==================== WEATHER MONITORING ====================
ENABLE_WEATHER_MONITORING=true

# Default monitoring location (Delhi, India)
DEFAULT_LATITUDE=28.7041
DEFAULT_LONGITUDE=77.1025
